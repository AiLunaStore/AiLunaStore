{
  "system": {
    "name": "OpenClaw Integrated Agent System",
    "version": "1.0.0",
    "environment": "production"
  },
  "server": {
    "port": 8080,
    "host": "localhost",
    "cors": {
      "enabled": true,
      "origins": ["http://localhost:8081", "http://localhost:3000"]
    }
  },
  "dashboard": {
    "port": 8081,
    "refreshInterval": 5000,
    "theme": "dark"
  },
  "costOptimization": {
    "enabled": true,
    "defaultBudget": 10.00,
    "alertThresholds": [0.5, 0.8, 0.95],
    "maxCostPerTask": 0.50,
    "savingsTarget": 0.40
  },
  "progressiveRefinement": {
    "enabled": true,
    "cheapThreshold": 0.75,
    "standardThreshold": 0.85,
    "criticalThreshold": 0.90,
    "maxStages": 3
  },
  "models": {
    "cheap": {
      "id": "deepseek-chat",
      "name": "DeepSeek V3",
      "maxTokens": 8000,
      "costPer1K": 0.0005
    },
    "standard": {
      "id": "kimi-k2.5",
      "name": "Kimi K2.5",
      "maxTokens": 32000,
      "costPer1K": 0.003
    },
    "premium": {
      "id": "gpt-5.1-codex",
      "name": "GPT-5.1 Codex",
      "maxTokens": 64000,
      "costPer1K": 0.015
    }
  },
  "agents": {
    "triage": {
      "model": "gpt-5-nano",
      "enabled": true
    },
    "planner": {
      "model": "deepseek-reasoner",
      "enabled": true
    },
    "implementer": {
      "model": "kimi-k2.5",
      "enabled": true
    },
    "reviewer": {
      "model": "gpt-5.1-codex",
      "enabled": true
    }
  },
  "logging": {
    "level": "info",
    "file": "logs/system.log",
    "maxSize": "10m",
    "maxFiles": 5
  }
}