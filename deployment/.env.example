# Mission Control Environment Configuration
# Copy this file to .env and customize for your deployment

# Server Configuration
PORT=8080
WS_PATH=/ws
NODE_ENV=production

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# Rate Limiting
RATE_LIMIT_WINDOW=60
RATE_LIMIT_MAX=100

# Budget Configuration
DEFAULT_BUDGET=10.00
BUDGET_ALERT_THRESHOLDS=0.5,0.8,0.95

# Execution Mode: 'progressive' or 'traditional'
EXECUTION_MODE=progressive

# Logging
LOG_LEVEL=info
LOG_FILE=logs/combined.log
ERROR_LOG_FILE=logs/error.log

# API Keys (if using real model APIs)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=
# GEMINI_API_KEY=
# MINIMAX_API_KEY=
