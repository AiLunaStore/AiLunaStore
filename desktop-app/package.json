{
  "name": "mission-control-desktop",
  "version": "1.0.0",
  "description": "Desktop application wrapper for Mission Control dashboard",
  "main": "main.js",
  "author": "OpenClaw",
  "license": "MIT",
  "homepage": "https://github.com/levinolonan/mission-control-desktop",
  "repository": {
    "type": "git",
    "url": "https://github.com/levinolonan/mission-control-desktop.git"
  },
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "build": "npm run build:mac && npm run build:win && npm run build:linux",
    "build:mac": "electron-builder --mac --universal",
    "build:mac-arm": "electron-builder --mac --arm64",
    "build:mac-intel": "electron-builder --mac --x64",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "postinstall": "electron-builder install-app-deps",
    "test": "echo \"No tests yet\" && exit 0"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.1.8",
    "electron-log": "^5.1.0",
    "electron-store": "^8.2.0"
  },
  "build": {
    "appId": "com.openclaw.mission-control",
    "productName": "Mission Control",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "settings.html",
      "icons/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.utilities",
      "target": [
        {
          "target": "dmg",
          "arch": ["universal", "arm64", "x64"]
        },
        {
          "target": "zip",
          "arch": ["universal", "arm64", "x64"]
        }
      ],
      "icon": "icons/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "ia32"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "icons/icon.ico",
      "publisherName": "OpenClaw"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "icon": "icons/png",
      "category": "Utility",
      "maintainer": "OpenClaw",
      "vendor": "OpenClaw",
      "synopsis": "Mission Control Dashboard",
      "description": "Desktop application wrapper for Mission Control agent monitoring dashboard"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mission Control"
    },
    "publish": {
      "provider": "github",
      "owner": "levinolonan",
      "repo": "mission-control-desktop",
      "releaseType": "release"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
