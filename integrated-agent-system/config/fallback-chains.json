          "rationale": "Fallback to DeepSeek for deeper analysis",
          "maxRetries": 2
        },
        {
          "model": "claude-sonnet",
          "agent": "research-specialist",
          "rationale": "Final fallback for complex research",
          "maxRetries": 1
        }
      ],
      "escalationRules": {
        "onFailure": "escalate_to_next",
        "onTimeout": "retry_then_escalate"
      }
    },
