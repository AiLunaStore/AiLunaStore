{
  "version": "1.1.0",
  "confidenceScoring": {
    "enabled": true,
    "weights": {
      "completeness": 0.25,
      "codeQuality": 0.25,
      "errorDetection": 0.20,
      "testCoverage": 0.15,
      "documentation": 0.10,
      "consistency": 0.05
    },
    "thresholds": {
      "cheap": 0.75,
      "standard": 0.85,
      "critical": 0.90
    },
    "adaptive": true,
    "learningRate": 0.02
  },
  "progressiveRefinement": {
    "enabled": true,
    "models": {
      "cheap": {
        "id": "deepseek-v3.2",
        "name": "DeepSeek V3.2",
        "costPer1MInput": 0.14,
        "costPer1MOutput": 0.28,
        "avgTokens": {
          "input": 2000,
          "output": 1500
        },
        "expectedSuccessRate": 0.70
      },
      "standard": {
        "id": "minimax-m2.5",
        "name": "MiniMax M2.5",
        "costPer1MInput": 0.30,
        "costPer1MOutput": 1.20,
        "avgTokens": {
          "input": 2000,
          "output": 1500
        },
        "expectedSuccessRate": 0.90
      },
      "premium": {
        "id": "kimi-k2.5",
        "name": "Kimi K2.5",
        "costPer1MInput": 0.60,
        "costPer1MOutput": 3.00,
        "avgTokens": {
          "input": 2000,
          "output": 1500
        },
        "expectedSuccessRate": 0.95
      }
    },
    "escalationRules": {
      "onLowConfidence": "escalate_to_next",
      "onCriticalTask": "always_use_premium",
      "onComplexity": {
        "threshold": 8,
        "action": "skip_cheap"
      }
    },
    "costOptimization": {
      "target": "minimize_expected_cost",
      "formula": "cost + (rerun_cost × failure_rate)",
      "maxStages": 3
    }
  },
  "criticalTaskDefinition": {
    "keywords": [
      "security",
      "authentication",
      "encryption",
      "payment",
      "production",
      "critical",
      "sensitive"
    ],
    "minComplexity": 8,
    "autoFlag": true
  },
  "taskTypeConfig": {
    "coding": {
      "useProgressive": true,
      "preferredModels": ["deepseek-v3.2", "minimax-m2.5", "kimi-k2.5"]
    },
    "research": {
      "useProgressive": false,
      "preferredModels": ["gemini-2.5-flash-lite", "deepseek-v3.2"]
    },
    "planning": {
      "useProgressive": false,
      "preferredModels": ["deepseek-reasoner", "claude-sonnet"]
    },
    "ui": {
      "useProgressive": true,
      "preferredModels": ["deepseek-v3.2", "minimax-m2.5"]
    },
    "backend": {
      "useProgressive": true,
      "preferredModels": ["deepseek-v3.2", "minimax-m2.5"]
    }
  }
