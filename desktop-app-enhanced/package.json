{
  "name": "openclaw-mission-control",
  "version": "1.0.0",
  "description": "Enhanced Mission Control desktop app for OpenClaw",
  "main": "src/main/main.js",
  "author": "OpenClaw Team",
  "license": "MIT",
  "homepage": "https://github.com/thizz23much/openclaw-mission-control",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron . --enable-logging",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "dist": "npm run build",
    "postinstall": "electron-builder install-app-deps",
    "test": "jest"
  },
  "build": {
    "appId": "com.openclaw.mission-control",
    "productName": "OpenClaw Mission Control",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "publisherName": "OpenClaw Team"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Office"
    },
    "publish": {
      "provider": "github",
      "owner": "thizz23much",
      "repo": "openclaw-mission-control",
      "releaseType": "release"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.13.3",
    "jest": "^29.7.0"
  },
  "dependencies": {
    "electron-log": "^5.0.1",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7",
    "ws": "^8.16.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "openclaw",
    "mission-control",
    "agent",
    "desktop",
    "electron"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/thizz23much/openclaw-mission-control.git"
  },
  "bugs": {
    "url": "https://github.com/thizz23much/openclaw-mission-control/issues"
  }
}
